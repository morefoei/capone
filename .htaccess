RewriteEngine On

# 1. Menyembunyikan ekstensi .html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L,QSA]

# Mengarahkan URL /cetak/ID/NAMA secara diam-diam ke cetak.php?id=ID&nama=NAMA
RewriteRule ^cetak/([0-9]+)/(.*)$ cetak.php?id=$1&nama=$2 [L,QSA]

# Menyembunyikan ekstensi .php secara umum
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]